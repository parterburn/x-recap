# Postgres connection. Railway sets this automatically when you attach a Postgres plugin.
DATABASE_URL=postgres://user:password@localhost:5432/x_recap_development

# X (Twitter) OAuth 2.0 app credentials. Get from https://developer.x.com.
X_CLIENT_ID=
X_CLIENT_SECRET=

# OpenAI API key — used by the digest summarizer.
OPENAI_ACCESS_TOKEN=

# Optional: an OpenAI org ID, if your account requires it.
# OPENAI_ORGANIZATION_ID=

# Mailgun. SMTP_DOMAIN is the sending domain (e.g. post.dabble.me).
MAILGUN_API_KEY=
SMTP_DOMAIN=

# Where digests come from and go to.
FROM_EMAIL=X Recap <no-reply@example.com>
TO_EMAIL=you@example.com

# The single user this app sends digests for. Created by `bin/setup-tokens`.
USER_EMAIL=you@example.com

# Optional: also push new bookmarks to Raindrop.io with this API key.
# RAINDROP_API_KEY=
