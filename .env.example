# Postgres connection. Railway sets this automatically when you attach a Postgres plugin.
DATABASE_URL=postgres://user:password@localhost:5432/x_recap_development

# X (Twitter) OAuth 2.0 app credentials. Get from https://developer.x.com.
X_CLIENT_ID=
X_CLIENT_SECRET=

# LLM credentials — used by the digest summarizer.
# Set AI_MODEL and at least one provider API key.
XAI_API_KEY=
OPENAI_API_KEY=
AI_MODEL=grok-4.3

# Mailgun. SMTP_DOMAIN is the sending domain (e.g. mg.example.com).
MAILGUN_API_KEY=
SMTP_DOMAIN=

# What appears in the digest's From: header.
FROM_EMAIL=X-Recap <no-reply@example.com>

# The single user this app runs for. Created by `bin/setup-tokens`.
# The digest is sent to this address.
USER_EMAIL=you@example.com
