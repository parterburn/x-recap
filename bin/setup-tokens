#!/usr/bin/env ruby
# One-time: save your X OAuth tokens and optional Raindrop API key to the user record.
# Usage: bin/setup-tokens <email> <x_access_token> <x_refresh_token> [raindrop_api_key]
# After this runs, the user row exists and tokens auto-refresh on every API call.

require_relative "../config/boot"

email, x_access_token, x_refresh_token, raindrop_api_key = ARGV
unless email && x_access_token && x_refresh_token
  abort "usage: bin/setup-tokens <email> <x_access_token> <x_refresh_token> [raindrop_api_key]"
end

user = User.find_or_initialize_by(email: email)
attrs = {
  x_access_token: x_access_token,
  x_refresh_token: x_refresh_token
}
attrs[:raindrop_api_key] = raindrop_api_key if raindrop_api_key.present?
user.update!(attrs)

client = XApiClient.new(access_token: x_access_token)
if (profile = client.current_user)
  user.update!(x_uid: profile.dig("data", "id"), x_username: profile.dig("data", "username"))
  puts "Saved tokens for @#{user.x_username} (uid=#{user.x_uid})."
else
  puts "Tokens saved, but couldn't fetch X profile. The token may already be expired — re-run if so."
  puts "Error: #{client.last_error}" if client.last_error.present?
end
