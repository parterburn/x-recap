#!/usr/bin/env ruby
# Sync the latest X bookmarks for the configured user.
# Usage: bin/sync [max_results]

require_relative "../config/boot"

email = ENV.fetch("USER_EMAIL")
max_results = (ARGV[0] || 30).to_i

user = User.find_by!(email: email)
abort "User #{email} is not connected to X (no refresh token)." unless user.x_connected?

count = XBookmark.sync_for_user!(user, max_results: max_results)
puts "Synced #{count} new bookmark#{count == 1 ? '' : 's'} for #{user.email}."
